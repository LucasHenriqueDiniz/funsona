---
import Layout from "@/layouts/Layout.astro";
import { getEntry, render } from "astro:content";

const locale = (Astro.currentLocale || "pt") as "pt" | "en" | "es";
const { slug } = Astro.params;
if (!slug) return Astro.redirect("/guides");

const entry = await getEntry("guides", `${locale}/${slug}`);
if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
const canonical = locale === "pt" ? `/guides/${slug}` : `/${locale}/guides/${slug}`;
const image = `${Astro.url.origin}/og-default.svg`;
---

<Layout title={`${entry.data.title} | FunSona`} description={entry.data.description} canonical={canonical}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description: entry.data.description,
    image,
    datePublished: entry.data.publishedDate.toISOString(),
    dateModified: (entry.data.updatedDate || entry.data.publishedDate).toISOString(),
    author: {
      "@type": "Person",
      name: "Lucas Henrique Diniz Ostroski",
    },
  })} />

  <main class="flex-1">
    <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
      <header class="mb-10">
        <h1 class="mb-4 text-3xl font-black text-[var(--color-text-primary)] sm:text-4xl">
          {entry.data.title}
        </h1>
        <p class="text-lg text-[var(--color-text-secondary)]">{entry.data.description}</p>
      </header>
      <div class="prose prose-indigo max-w-none text-[var(--color-text-secondary)]">
        <Content />
      </div>
    </article>
  </main>
</Layout>
