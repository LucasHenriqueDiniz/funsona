---
import Layout from "@/layouts/Layout.astro";
import QuizExitControl from "@/components/quiz/QuizExitControl";
import QuizPlay from "@/components/quiz/QuizPlay";
import { apiFetch } from "@/lib/api";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/");

const { data: quiz, error } = await apiFetch(`/quizzes/${slug}`);

if (error || !quiz) {
  return Astro.redirect("/404");
}

const title = `${quiz.title} | FunSona`;
const description = quiz.description || `Jogue o quiz ${quiz.title} no FunSona`;
---

<Layout title={title} description={description} canonical={`/quiz/${slug}/play`} hideFooter>
  <div class="relative min-h-screen overflow-hidden bg-[#070816] text-white">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-28 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full bg-brand-500/30 blur-[110px]"></div>
      <div class="absolute top-1/3 -left-24 h-72 w-72 rounded-full bg-accent-500/20 blur-[100px]"></div>
      <div class="absolute bottom-0 right-0 h-96 w-96 translate-x-1/3 translate-y-1/3 rounded-full bg-cyan-400/10 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08),transparent_35%),linear-gradient(180deg,rgba(7,8,22,0.15),#070816_80%)]"></div>
    </div>

    <div class="relative z-10 flex min-h-[calc(100vh-5.8rem)] flex-col">
      <main class="flex flex-1 items-center px-4 py-6 sm:px-6 sm:py-10 lg:px-8">
        <div class="mx-auto w-full max-w-6xl">
          <QuizExitControl href={`/quiz/${slug}`} client:load />
          <QuizPlay quiz={quiz} client:load />
        </div>
      </main>
    </div>
  </div>
</Layout>
