---
interface Props {
  quizCount?: number;
  playCount?: number;
}

const { quizCount = 0, playCount = 0 } = Astro.props;
---

<section class="relative overflow-hidden rounded-2xl sm:rounded-3xl bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <defs>
        <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="white"/>
        </pattern>
      </defs>
      <rect width="100" height="100" fill="url(#grid)"/>
    </svg>
  </div>

  <div class="relative px-5 py-12 sm:px-8 sm:py-16 lg:px-12 lg:py-20 text-center">
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4 sm:mb-6 leading-tight">
      Descubra, crie e compartilhe<br class="hidden sm:inline"/>
      <span class="text-yellow-300">quizzes incríveis</span>
    </h1>

    <p class="text-base sm:text-lg md:text-xl text-indigo-100 max-w-2xl mx-auto mb-6 sm:mb-8 px-2">
      Milhares de quizzes para jogar. Crie o seu em minutos e compartilhe com o mundo.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center mb-10 sm:mb-12">
      <a 
        href="/explore" 
        class="px-6 py-3 sm:px-8 sm:py-4 bg-white text-indigo-600 font-bold rounded-xl hover:bg-indigo-50 transition shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 text-sm sm:text-base"
      >
        Explorar Quizzes
      </a>
      <a 
        href="/quiz/new" 
        class="px-6 py-3 sm:px-8 sm:py-4 bg-indigo-500/30 backdrop-blur-sm text-white font-bold rounded-xl border-2 border-white/30 hover:bg-indigo-500/50 transition text-sm sm:text-base"
      >
        Criar Quiz
      </a>
    </div>

    <!-- Stats -->
    <div class="flex justify-center gap-6 sm:gap-8 lg:gap-12">
      <div class="text-center">
        <div class="text-2xl sm:text-3xl lg:text-4xl font-bold">{quizCount.toLocaleString('pt-BR')}</div>
        <div class="text-xs sm:text-sm text-indigo-200">Quizzes</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl lg:text-4xl font-bold">{playCount.toLocaleString('pt-BR')}</div>
        <div class="text-xs sm:text-sm text-indigo-200">Jogadas</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl lg:text-4xl font-bold">Gratuito</div>
        <div class="text-xs sm:text-sm text-indigo-200">Para sempre</div>
      </div>
    </div>
  </div>
</section>
