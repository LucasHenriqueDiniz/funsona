# Security Headers - Applied to all routes
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://www.googletagmanager.com https://www.google-analytics.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com;
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: no-referrer-when-downgrade

# Cache explore pages at the edge for fast category switching
/explore
  Cache-Control: public, s-maxage=30, stale-while-revalidate=60

/explore/*
  Cache-Control: public, s-maxage=30, stale-while-revalidate=60

# Cache static assets aggressively (they have content hashes in filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache auth or user-specific pages
/auth/*
  Cache-Control: no-store

/profile/*
  Cache-Control: no-store

/settings
  Cache-Control: no-store
