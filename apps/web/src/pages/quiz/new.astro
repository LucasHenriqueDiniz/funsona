---
import Layout from "@/layouts/Layout.astro";
import QuizEditor from "@/components/quiz/QuizEditor";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}
---

<Layout title="Criar Quiz | FunSona" description="Crie seu próprio quiz no FunSona.">

  <!-- ══════════════════════════════ HERO ══════════════════════════════ -->
  <div class="bg-slate-900 border-b border-slate-800">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-brand-500/15 text-2xl">✏️</div>
        <div class="min-w-0">
          <p class="mb-0.5 text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Criação</p>
          <h1 class="text-2xl font-black leading-tight text-white sm:text-3xl">Novo quiz</h1>
        </div>

        <div class="ml-auto hidden items-center gap-2 sm:flex">
          {[["📋", "Básico"], ["❓", "Perguntas"], ["🚀", "Publicar"]].map(([emoji, label]) => (
            <div class="flex items-center gap-1.5 rounded-xl bg-slate-800 px-3 py-2 text-sm font-semibold text-slate-400">
              <span>{emoji}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <QuizEditor client:load />
  </div>

</Layout>
