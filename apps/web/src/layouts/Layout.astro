---
import "@/styles/global.css";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  transparentNav?: boolean;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { title, description = "FunSona - Crie e jogue quizzes incríveis", image = "/og-default.svg", canonical, transparentNav, hideNav = false, hideFooter = false } = Astro.props;
const siteUrl = Astro.site || new URL(Astro.url.origin);
const toAbsoluteUrl = (value: string) => new URL(value, siteUrl).toString();
const url = canonical ? toAbsoluteUrl(canonical) : Astro.url.href;
const imageUrl = toAbsoluteUrl(image);
const locales = ["pt", "en", "es"] as const;
const defaultLocale = "pt";
const nonDefaultLocales = locales.filter((locale) => locale !== defaultLocale);
const pathname = new URL(url).pathname;
const normalizedPath = (() => {
  for (const locale of nonDefaultLocales) {
    if (pathname === `/${locale}`) return "/";
    if (pathname.startsWith(`/${locale}/`)) {
      return pathname.slice(locale.length + 1) || "/";
    }
  }
  return pathname || "/";
})();
const localizedUrls = locales.map((locale) => {
  const localizedPath = locale === defaultLocale
    ? normalizedPath
    : normalizedPath === "/"
      ? `/${locale}`
      : `/${locale}${normalizedPath}`;
  return {
    locale,
    href: toAbsoluteUrl(localizedPath),
  };
});
const xDefaultHref = localizedUrls.find((entry) => entry.locale === defaultLocale)?.href || url;

const gaId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;
const adsenseClient = import.meta.env.PUBLIC_GOOGLE_ADSENSE_CLIENT;
---

<!DOCTYPE html>
<html lang={Astro.currentLocale || "pt"}>
<head>
  <script is:inline>
    function applyTheme() {
      const theme = localStorage.getItem("funsona-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const isDark = theme === "dark" || (!theme && prefersDark);
      document.documentElement.setAttribute("data-theme", isDark ? "dark" : "light");
    }
    applyTheme();
    // Re-apply after each View Transition swap so theme is never lost
    document.addEventListener("astro:after-swap", applyTheme);
  </script>
  <script is:inline>
    (function() {
      if (window.location.pathname === "/auth/callback") return;
      const hash = window.location.hash || "";
      const isOAuthReturn = hash.includes("access_token=") || hash.includes("error_description=");
      if (isOAuthReturn) {
        window.location.replace("/auth/callback" + hash);
      }
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  {localizedUrls.map((entry) => (
    <link rel="alternate" hreflang={entry.locale} href={entry.href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />

  <!-- View Transitions: client-side navigation with smooth page transitions -->
  <ViewTransitions fallback="animate" />

  <!-- Prefetch key pages -->
  <link rel="prefetch" href="/explore" />
  <link rel="prefetch" href="/leaderboard" />
  <link rel="prefetch" href="/login" />

  <!-- Structured Data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "FunSona",
    url: siteUrl.toString(),
  })} />

  <!-- Google Analytics -->
  {gaId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, {
          'anonymize_ip': true,
          'allow_google_signals': false,
          'allow_ad_personalization_signals': false,
          'restricted_data_processing': true
        });
      </script>
    </>
  )}

  <!-- Google AdSense -->
  {adsenseClient && (
    <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous" />
  )}
</head>
<body class="bg-[var(--color-surface)] text-[var(--color-text-primary)] min-h-screen flex flex-col transition-colors duration-300">
  {!hideNav && <Navbar transparent={transparentNav} transition:persist />}

  <main class="flex-1">
    <slot />
  </main>

  {!hideFooter && <Footer transition:persist />}
</body>
</html>
